// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User Model - نموذج المستخدم
model User {
  id            String    @id @default(cuid())
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  email         String?   @unique
  phone         String?   @unique
  password      String
  role          Role      @default(USER)
  additionalRoles Role[]  @default([]) @map("additional_roles")
  image         String?   @default("/images/default-avatar.svg")
  emailVerified DateTime? @map("email_verified")
  phoneVerified DateTime? @map("phone_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // العلاقات
  feasibilityStudies FeasibilityStudy[] @relation("AdminStudies")

  // علاقات نظام الدورات
  adminCourses      Course[]             @relation("AdminCourses")
  enrollments       CourseEnrollment[]   @relation("UserEnrollments")
  coursePayments    CoursePayment[]      @relation("UserCoursePayments")
  lessonProgress    LessonProgress[]     @relation("UserProgress")
  lessonComments    LessonComment[]      @relation("UserComments")
  lessonLikes       LessonLike[]         @relation("UserLikes")
  lessonDislikes    LessonDislike[]      @relation("UserDislikes")
  courseReviews     CourseReview[]        @relation("UserReviews")

  // علاقات نظام الحسابات
  investments       ApartmentInvestor[]
  createdBookings   Booking[]    @relation("BookingCreator")
  createdExpenses   Expense[]    @relation("ExpenseCreator")
  assignedApartments OpsManagerApartment[]
  custodyRecords    Custody[]    @relation("CustodyManager")
  approvedExpenses  Expense[]    @relation("ExpenseApprover")

  @@map("users")
}

// Role Enum - أدوار المستخدمين
enum Role {
  USER              // مستخدم عادي
  ADMIN             // مدير (النظام القديم)
  GENERAL_MANAGER   // المدير العام - صلاحيات كاملة
  OPS_MANAGER       // مدير التشغيل - مصروفات + متابعة يومية
  BOOKING_MANAGER   // مدير الحجوزات - إضافة وتعديل الحجوزات
  INVESTOR          // المستثمر - عرض حساباته فقط
}

// Consultation Status - حالات طلب الاستشارة
enum ConsultationStatus {
  PENDING   // جديد - في انتظار المراجعة
  ACCEPTED  // مقبول (قيمة قديمة - محفوظة للتوافق)
  REJECTED  // مرفوض (قيمة قديمة - محفوظة للتوافق)
  READ      // تم القراءة
  COMPLETED // مكتمل
}

// Feasibility Study Status - حالات دراسة الجدوى
enum StudyStatus {
  DRAFT     // مسودة
  SENT      // تم الإرسال
  VIEWED    // تمت المشاهدة
}

// نوع العقار - Property Type
enum PropertyType {
  APARTMENT     // شقة
  VILLA         // فيلا
  STUDIO        // استوديو
  DUPLEX        // دوبلكس
  PENTHOUSE     // بنتهاوس
  CHALET        // شاليه
  OTHER         // أخرى
}

// نوع دراسة الجدوى - Study Request Type
enum StudyRequestType {
  WITHOUT_FIELD_VISIT   // بدون نزول ميداني
  WITH_FIELD_VISIT      // مع نزول ميداني
}

// حالة طلب دراسة الجدوى - Feasibility Request Status
enum FeasibilityRequestStatus {
  PENDING       // في الانتظار
  IN_PROGRESS   // قيد المعالجة
  COMPLETED     // مكتمل
  REJECTED      // مرفوض
}

// ============================================================================
// Enums - نظام الدورات التدريبية
// ============================================================================

// مستوى الدورة
enum CourseLevel {
  BEGINNER      // مبتدئ
  INTERMEDIATE  // متوسط
  ADVANCED      // متقدم
}

// حالة الاشتراك في الدورة
enum EnrollmentStatus {
  PENDING       // في انتظار تأكيد الدفع
  CONFIRMED     // تم التأكيد - نشط
  EXPIRED       // منتهي الصلاحية
  REFUNDED      // مسترد
}

// حالة الدفع الإلكتروني
enum PaymentStatus {
  PENDING       // في انتظار نتيجة Paymob
  PAID          // تم الدفع بنجاح
  FAILED        // فشل الدفع
  CANCELLED     // تم الإلغاء أو العكس
}

// مزود الدفع
enum PaymentProvider {
  PAYMOB
}

// Consultation Model - نموذج طلب الاستشارة
model Consultation {
  id          String             @id @default(cuid())
  firstName   String             @map("first_name")
  lastName    String             @map("last_name")
  email       String
  phone       String?
  message     String
  
  // تكوين الشقة (اختياري)
  bedrooms    Int?               @default(0)
  livingRooms Int?               @default(0) @map("living_rooms")
  kitchens    Int?               @default(0)
  bathrooms   Int?               @default(0)
  
  status      ConsultationStatus @default(PENDING)
  
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@map("consultations")
}

// Feasibility Study Model - نموذج دراسة الجدوى
model FeasibilityStudy {
  id          String      @id @default(cuid())
  title       String
  clientName  String      @map("client_name")
  clientEmail String?     @map("client_email")
  clientPhone String?     @map("client_phone")
  
  // نوع الدراسة
  studyType   StudyRequestType  @default(WITH_FIELD_VISIT) @map("study_type")
  
  // بيانات الشرائح (JSON)
  slides      Json
  
  // تكوين الغرف
  bedrooms    Int         @default(1)
  livingRooms Int         @default(1) @map("living_rooms")
  kitchens    Int         @default(0)
  bathrooms   Int         @default(1)
  
  // التكلفة الإجمالية
  totalCost   Float       @default(0) @map("total_cost")
  
  // العملة المستخدمة
  currency    String      @default("EGP")
  
  // الحالة
  status      StudyStatus @default(DRAFT)
  
  // رابط المشاركة
  shareId     String?     @unique @map("share_id")
  
  // الأدمن المسؤول
  admin       User        @relation("AdminStudies", fields: [adminId], references: [id])
  adminId     String      @map("admin_id")
  
  // طلب دراسة الجدوى المرتبط (اختياري)
  feasibilityRequest   FeasibilityRequest? @relation("RequestStudy", fields: [feasibilityRequestId], references: [id])
  feasibilityRequestId String?             @unique @map("feasibility_request_id")
  
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  sentAt      DateTime?   @map("sent_at")
  viewedAt    DateTime?   @map("viewed_at")

  @@map("feasibility_studies")
}

// Feasibility Request Model - نموذج طلب دراسة الجدوى (النظام الجديد)
model FeasibilityRequest {
  id              String                    @id @default(cuid())
  
  // نوع الدراسة
  studyType       StudyRequestType          @map("study_type")
  
  // بيانات العميل
  fullName        String                    @map("full_name")
  phone           String                    // رقم الهاتف للتحقق (مطلوب)
  phoneVerified   Boolean                   @default(false) @map("phone_verified")
  
  // بيانات العقار
  propertyType    PropertyType              @map("property_type")
  bedrooms        Int                       @default(1)
  livingRooms     Int                       @default(1) @map("living_rooms")
  kitchens        Int                       @default(0)
  bathrooms       Int                       @default(1)
  
  // بيانات الموقع
  city            String
  district        String
  googleMapsUrl   String?                   @map("google_maps_url")
  latitude        Float?
  longitude       Float?
  
  // الحالة
  status          FeasibilityRequestStatus  @default(PENDING)
  
  // رمز الدفع - يتم إنشاؤه تلقائياً لكل طلب
  paymentCode     String                    @unique @map("payment_code")
  
  // ملاحظات الأدمن
  adminNotes      String?                   @map("admin_notes")
  
  // العلاقة مع دراسة الجدوى (عند إنشائها)
  feasibilityStudy FeasibilityStudy?        @relation("RequestStudy")
  
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  @@map("feasibility_requests")
}

// Email Verification Model - نموذج التحقق من البريد الإلكتروني (Legacy)
model EmailVerification {
  id          String    @id @default(cuid())
  email       String
  code        String
  expiresAt   DateTime  @map("expires_at")
  verified    Boolean   @default(false)
  verifiedAt  DateTime? @map("verified_at")
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([email, code])
  @@index([email, expiresAt])
  @@map("email_verifications")
}

// Phone Verification Model - نموذج التحقق من رقم الهاتف
model PhoneVerification {
  id              String    @id @default(cuid())
  phoneNumber     String    @map("phone_number")
  firebaseUid     String?   @map("firebase_uid")     // Firebase user ID after verification
  verified        Boolean   @default(false)
  verifiedAt      DateTime? @map("verified_at")
  expiresAt       DateTime  @map("expires_at")       // Verification validity (24 hours)
  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([phoneNumber, verified])                   // Only one verified record per phone
  @@index([phoneNumber, expiresAt])
  @@index([phoneNumber, verified])
  @@map("phone_verifications")
}

// Library Item Customization - تخصيصات عناصر المكتبة (الأسعار والصور والأوصاف)
model LibraryItemCustomization {
  id           String   @id @default(cuid())
  
  // معرف العنصر في المكتبة (مثل: fridge, double-bed, toilet)
  itemId       String   @unique @map("item_id")
  
  // نوع الغرفة (bedroom, kitchen, bathroom, living-room)
  roomType     String   @map("room_type")
  
  // السعر المخصص (آخر سعر تم إدخاله)
  customPrice  Float?   @map("custom_price")
  
  // صورة العنصر (Base64 أو رابط Vercel Blob)
  image        String?  @db.Text
  
  // وصف العنصر المخصص
  description  String?  @db.Text
  
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([roomType])
  @@map("library_item_customizations")
}

// Password Reset Model - نموذج إعادة تعيين كلمة المرور
model PasswordReset {
  id          String    @id @default(cuid())
  email       String?
  phone       String?
  code        String                               // 6-digit OTP code
  expiresAt   DateTime  @map("expires_at")         // 10 minutes validity
  used        Boolean   @default(false)
  usedAt      DateTime? @map("used_at")
  attempts    Int       @default(0)                // Failed verification attempts
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([email, code])
  @@index([phone, code])
  @@index([email, expiresAt])
  @@index([phone, expiresAt])
  @@map("password_resets")
}

// ============================================================================
// نظام الدورات التدريبية - Courses System
// ============================================================================

// Course Model - نموذج الدورة
model Course {
  id               String            @id @default(cuid())
  title            String                                    // اسم الدورة
  slug             String            @unique                  // رابط URL فريد
  description      String            @db.Text                 // وصف تفصيلي
  shortDescription String?           @map("short_description") // وصف مختصر للبطاقة
  price            Float                                      // السعر بالجنيه
  currency         String            @default("EGP")
  thumbnailUrl     String?           @map("thumbnail_url")    // صورة غلاف الدورة
  previewVideoUrl  String?           @map("preview_video_url") // فيديو تعريفي
  features         Json?                                      // قائمة مميزات الدورة ["ميزة 1", "ميزة 2"]
  level            CourseLevel       @default(BEGINNER)        // مستوى الدورة
  isPublished      Boolean           @default(false) @map("is_published")
  sortOrder        Int               @default(0) @map("sort_order")

  // إحصائيات محسوبة (تُحدّث عند تعديل الدروس)
  totalDuration    Int               @default(0) @map("total_duration")  // إجمالي المدة بالثواني
  lessonsCount     Int               @default(0) @map("lessons_count")   // عدد الدروس

  // العلاقات
  sections         CourseSection[]
  enrollments      CourseEnrollment[]
  payments         CoursePayment[]
  reviews          CourseReview[]

  // الأدمن المنشئ
  admin            User              @relation("AdminCourses", fields: [adminId], references: [id])
  adminId          String            @map("admin_id")

  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@index([isPublished])
  @@index([sortOrder])
  @@map("courses")
}

// CourseSection Model - أقسام الدورة
model CourseSection {
  id          String         @id @default(cuid())
  title       String                                         // عنوان القسم
  sortOrder   Int            @default(0) @map("sort_order")

  course      Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId     String         @map("course_id")

  lessons     CourseLesson[]

  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@index([courseId, sortOrder])
  @@map("course_sections")
}

// CourseLesson Model - دروس الدورة
model CourseLesson {
  id            String           @id @default(cuid())
  title         String                                       // عنوان الدرس
  description   String?                                      // وصف اختياري
  videoUrl      String           @map("video_url")           // رابط الفيديو
  duration      Int              @default(0)                 // المدة بالثواني
  sortOrder     Int              @default(0) @map("sort_order")
  isFree        Boolean          @default(false) @map("is_free") // درس مجاني (معاينة)

  section       CourseSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId     String           @map("section_id")

  // العلاقات
  progress      LessonProgress[]
  comments      LessonComment[]
  likes         LessonLike[]
  dislikes      LessonDislike[]

  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@index([sectionId, sortOrder])
  @@map("course_lessons")
}

// CourseEnrollment Model - اشتراكات الدورات
model CourseEnrollment {
  id               String           @id @default(cuid())
  status           EnrollmentStatus @default(PENDING)
  paymentCode      String           @unique @map("payment_code")  // رمز الدفع (6 أحرف)

  user             User             @relation("UserEnrollments", fields: [userId], references: [id], onDelete: Cascade)
  userId           String           @map("user_id")

  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId          String           @map("course_id")

  payment          CoursePayment?    @relation(fields: [paymentId], references: [id])
  paymentId        String?           @unique @map("payment_id")

  // بيانات الدفع
  phone            String                                         // رقم الهاتف
  phoneVerified    Boolean          @default(false) @map("phone_verified")
  amount           Float                                          // المبلغ المدفوع

  // تتبع التقدم
  completedLessons Int              @default(0) @map("completed_lessons")
  lastAccessedAt   DateTime?        @map("last_accessed_at")
  completedAt      DateTime?        @map("completed_at")

  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@unique([userId, courseId])    // مستخدم واحد = اشتراك واحد لكل دورة
  @@index([status])
  @@index([courseId])
  @@index([paymentCode])
  @@map("course_enrollments")
}

// CoursePayment Model - محاولات دفع الدورات عبر Paymob
model CoursePayment {
  id                    String          @id @default(cuid())
  status                PaymentStatus   @default(PENDING)
  provider              PaymentProvider @default(PAYMOB)

  user                  User            @relation("UserCoursePayments", fields: [userId], references: [id], onDelete: Cascade)
  userId                String          @map("user_id")

  course                Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId              String          @map("course_id")

  enrollment            CourseEnrollment?

  amount                Float
  currency              String          @default("EGP")
  phone                 String
  billingName           String          @map("billing_name")
  billingEmail          String          @map("billing_email")

  providerOrderId       String?         @map("provider_order_id")
  providerTransactionId String?         @unique @map("provider_transaction_id")
  checkoutUrl           String?         @db.Text @map("checkout_url")
  clientSecret          String?         @db.Text @map("client_secret")
  metadata              Json?

  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  @@index([userId, courseId])
  @@index([courseId])
  @@index([status])
  @@index([providerOrderId])
  @@map("course_payments")
}

// LessonProgress Model - تقدم مشاهدة الدروس
model LessonProgress {
  id              String        @id @default(cuid())
  watchedSeconds  Int           @default(0) @map("watched_seconds")   // الثواني المشاهدة
  isCompleted     Boolean       @default(false) @map("is_completed")
  lastPosition    Int           @default(0) @map("last_position")     // آخر موضع للمتابعة (بالثواني)

  user            User          @relation("UserProgress", fields: [userId], references: [id])
  userId          String        @map("user_id")

  lesson          CourseLesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId        String        @map("lesson_id")

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("lesson_progress")
}

// LessonComment Model - تعليقات الدروس
model LessonComment {
  id          String          @id @default(cuid())
  content     String          @db.Text

  user        User            @relation("UserComments", fields: [userId], references: [id])
  userId      String          @map("user_id")

  lesson      CourseLesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId    String          @map("lesson_id")

  // الردود - مستوى واحد فقط
  parent      LessonComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  parentId    String?         @map("parent_id")
  replies     LessonComment[] @relation("CommentReplies")

  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@index([lessonId, createdAt])
  @@index([parentId])
  @@map("lesson_comments")
}

// LessonLike Model - إعجابات الدروس
model LessonLike {
  id        String        @id @default(cuid())

  user      User          @relation("UserLikes", fields: [userId], references: [id])
  userId    String        @map("user_id")

  lesson    CourseLesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId  String        @map("lesson_id")

  createdAt DateTime      @default(now()) @map("created_at")

  @@unique([userId, lessonId])  // لايك واحد لكل مستخدم لكل درس
  @@index([lessonId])
  @@map("lesson_likes")
}

// LessonDislike Model - عدم إعجاب الدروس
model LessonDislike {
  id        String        @id @default(cuid())

  user      User          @relation("UserDislikes", fields: [userId], references: [id])
  userId    String        @map("user_id")

  lesson    CourseLesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId  String        @map("lesson_id")

  createdAt DateTime      @default(now()) @map("created_at")

  @@unique([userId, lessonId])
  @@index([lessonId])
  @@map("lesson_dislikes")
}

// CourseReview Model - تقييمات الدورات
model CourseReview {
  id        String   @id @default(cuid())
  rating    Int                                  // 1-5 نجوم
  comment   String?  @db.Text                    // تعليق اختياري

  user      User     @relation("UserReviews", fields: [userId], references: [id])
  userId    String   @map("user_id")

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId   String   @map("course_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, courseId])  // تقييم واحد لكل مستخدم لكل دورة
  @@index([courseId])
  @@map("course_reviews")
}

// ============================================================================
// نظام الحسابات - Accounting System
// ============================================================================

// Project Model - نموذج المشروع
model Project {
  id          String      @id @default(cuid())
  name        String                               // اسم المشروع (مثلاً: المنيل)
  description String?
  apartments  Apartment[]
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("projects")
}

// Apartment Model - نموذج الشقة
model Apartment {
  id              String              @id @default(cuid())
  name            String                                  // اسم الشقة (مثلاً: المنيل - الدور الخامس)
  floor           String?                                 // رقم الدور
  type            String?                                 // نوع الشقة (عادي / بانوراما)
  project         Project             @relation(fields: [projectId], references: [id])
  projectId       String              @map("project_id")

  // العلاقات
  bookings         Booking[]
  expenses         Expense[]
  investors        ApartmentInvestor[]
  monthlySnapshots MonthlySnapshot[]
  assignedManagers OpsManagerApartment[]
  custodyRecords   Custody[]

  isActive        Boolean             @default(true) @map("is_active")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("apartments")
}

// Booking Model - نموذج الحجز
model Booking {
  id              String        @id @default(cuid())
  apartment       Apartment     @relation(fields: [apartmentId], references: [id])
  apartmentId     String        @map("apartment_id")

  // بيانات العميل
  clientName      String        @map("client_name")
  clientPhone     String?       @map("client_phone")

  // تفاصيل الحجز
  checkIn         DateTime      @map("check_in")          // تاريخ الدخول
  checkOut        DateTime      @map("check_out")         // تاريخ الخروج
  nights          Int                                      // عدد الليالي (محسوب)
  amount          Float                                    // القيمة المالية للحجز
  currency        String        @default("USD")
  source          BookingSource                            // مصدر الحجز

  // بيانات الوصول
  arrivalTime     String?       @map("arrival_time")      // وقت الوصول
  flightNumber    String?       @map("flight_number")     // رقم الرحلة
  notes           String?                                  // ملاحظات أخرى

  // المشرفين
  receptionSupervisor  String?  @map("reception_supervisor")   // مشرف الاستقبال
  deliverySupervisor   String?  @map("delivery_supervisor")    // مشرف الاستلام (الخروج)

  // الحالة
  status          BookingStatus @default(CONFIRMED)

  // 🔒 Soft Delete - لا نحذف البيانات المالية فعلياً
  deletedAt       DateTime?     @map("deleted_at")

  createdBy       User          @relation("BookingCreator", fields: [createdById], references: [id])
  createdById     String        @map("created_by_id")

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Indexes للأداء - فلترة بالشقة والشهر
  @@index([apartmentId, checkIn])
  @@index([apartmentId, checkOut])
  @@index([deletedAt])
  @@index([createdById])
  @@index([status])
  @@index([source])
  @@map("bookings")
}

// مصدر الحجز
enum BookingSource {
  AIRBNB
  EXTERNAL        // خارجي
  DIRECT          // مباشر
  BOOKING_COM
  OTHER
}

// حالة الحجز
enum BookingStatus {
  CONFIRMED       // مؤكد
  CHECKED_IN      // تم الدخول
  CHECKED_OUT     // تم الخروج
  CANCELLED       // ملغي
}

// Expense Model - نموذج المصروفات
model Expense {
  id              String          @id @default(cuid())
  apartment       Apartment       @relation(fields: [apartmentId], references: [id])
  apartmentId     String          @map("apartment_id")

  description     String                                // الوصف
  category        ExpenseCategory                       // القسم (نظافة، انترنت، مياه...)
  amount          Float                                 // المبلغ
  currency        String          @default("USD")
  date            DateTime                              // تاريخ المصروف
  notes           String?

  // ✅ حالة الاعتماد - المصروفات تحتاج موافقة المدير العام
  approvalStatus  ExpenseApproval @default(PENDING) @map("approval_status")
  approvedBy      User?           @relation("ExpenseApprover", fields: [approvedById], references: [id])
  approvedById    String?         @map("approved_by_id")
  approvedAt      DateTime?       @map("approved_at")
  rejectionReason String?         @map("rejection_reason")

  // 🔒 Soft Delete
  deletedAt       DateTime?       @map("deleted_at")

  createdBy       User            @relation("ExpenseCreator", fields: [createdById], references: [id])
  createdById     String          @map("created_by_id")

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Indexes للأداء
  @@index([apartmentId, date])
  @@index([deletedAt])
  @@index([createdById])
  @@index([category])
  @@index([approvalStatus])
  @@map("expenses")
}

// حالة اعتماد المصروف
enum ExpenseApproval {
  PENDING           // في انتظار الموافقة
  APPROVED          // معتمد من المدير العام
  REJECTED          // مرفوض
}

// أقسام المصروفات
enum ExpenseCategory {
  CLEANING           // تنظيف الشقة
  INTERNET           // انترنت
  WATER              // مياه
  GAS                // غاز
  ELECTRICITY        // كهرباء
  MAINTENANCE        // صيانة
  SUPPLIES           // مستلزمات (صابون، مناشيل...)
  FURNITURE          // أثاث
  LAUNDRY            // غسيل ملاءات
  TOWELS             // مناشيل حمام
  KITCHEN_SUPPLIES   // مستلزمات المطبخ
  AIR_CONDITIONING   // تكييف
  OTHER              // أخرى
}

// ApartmentInvestor Model - نموذج المستثمر في الشقة (جدول وسيط)
model ApartmentInvestor {
  id               String       @id @default(cuid())
  apartment        Apartment    @relation(fields: [apartmentId], references: [id])
  apartmentId      String       @map("apartment_id")
  user             User         @relation(fields: [userId], references: [id])
  userId           String       @map("user_id")

  percentage       Float                                // نسبة المستثمر (مثلاً 0.20 = 20%)
  investmentTarget Float        @default(0) @map("investment_target") // الهدف السنوي للاستثمار

  // العلاقات
  withdrawals              Withdrawal[]
  monthlyInvestorSnapshots MonthlyInvestorSnapshot[]

  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // يمنع تكرار نفس المستثمر في نفس الشقة
  @@unique([apartmentId, userId])
  @@index([userId])
  @@map("apartment_investors")
}

// Withdrawal Model - نموذج المسحوبات
model Withdrawal {
  id                    String             @id @default(cuid())
  apartmentInvestor     ApartmentInvestor  @relation(fields: [apartmentInvestorId], references: [id])
  apartmentInvestorId   String             @map("apartment_investor_id")

  amount                Float                              // المبلغ المسحوب
  currency              String             @default("USD")
  date                  DateTime                           // تاريخ السحب
  comments              String?                            // ملاحظات

  // 🔒 Soft Delete
  deletedAt             DateTime?          @map("deleted_at")

  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  @@index([apartmentInvestorId])
  @@index([deletedAt])
  @@index([date])
  @@map("withdrawals")
}

// CurrencyRate Model - نموذج سعر صرف العملة
// سعر صرف شهري مستقل لكل شهر
model CurrencyRate {
  id            String   @id @default(cuid())
  fromCurrency  String   @map("from_currency")      // مثلاً: USD
  toCurrency    String   @map("to_currency")         // مثلاً: EGP
  rate          Float                                 // سعر الصرف
  month         String                                // "YYYY-MM"
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([fromCurrency, toCurrency, month])
  @@index([month])
  @@map("currency_rates")
}

// MonthlySnapshot Model - نموذج الملخص الشهري (للأداء)
// ⚡ يُحسب مسبقاً ويُحدّث تلقائياً عند كل عملية مالية
model MonthlySnapshot {
  id              String    @id @default(cuid())
  apartment       Apartment @relation(fields: [apartmentId], references: [id])
  apartmentId     String    @map("apartment_id")
  month           String                               // "2026-03" format

  // الأرقام المحسوبة
  totalRevenue    Float     @default(0) @map("total_revenue")
  totalExpenses   Float     @default(0) @map("total_expenses")
  profit          Float     @default(0)
  bookingsCount   Int       @default(0) @map("bookings_count")
  occupiedNights  Int       @default(0) @map("occupied_nights")

  // تقسيم الإيرادات حسب المصدر
  revenueBySource Json?     @map("revenue_by_source")  // { "AIRBNB": 5000, "DIRECT": 2000, ... }

  // تقسيم المصروفات حسب القسم
  expensesByCategory Json?  @map("expenses_by_category") // { "CLEANING": 400, "INTERNET": 200, ... }

  // 🔒 قفل الشهر - لمنع التعديل والحفاظ على تاريخ النسب
  isLocked        Boolean   @default(false) @map("is_locked")
  lockedAt        DateTime? @map("locked_at")
  lockedById      String?   @map("locked_by_id")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // كل شقة لها ملخص واحد فقط لكل شهر
  @@unique([apartmentId, month])
  @@index([month])
  @@index([isLocked])
  @@map("monthly_snapshots")
}

// SystemSetting Model - إعدادات النظام (مفتاح → قيمة JSON)
// تُستخدم لتخزين إعدادات مثل قائمة المشرفين وأقسام المصروفات المخصصة
model SystemSetting {
  key       String   @id                       // e.g. "supervisors", "expense_categories"
  value     Json                               // القيمة بصيغة JSON
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ============================================================================
// Enterprise Features - ميزات المؤسسات
// ============================================================================

// AuditLog Model - سجل المراجعة (تتبع كل العمليات)
// 🔒 يسجل مَن فعل ماذا ومتى مع القيم قبل وبعد التغيير
model AuditLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")           // معرف المستخدم الذي نفذ العملية
  userName    String   @map("user_name")          // اسم المستخدم (محفوظ للعرض بدون join)

  action      String                              // CREATE | UPDATE | DELETE | LOCK_MONTH | UNLOCK_MONTH | WITHDRAWAL
  entity      String                              // BOOKING | EXPENSE | INVESTOR | WITHDRAWAL | MONTH
  entityId    String?  @map("entity_id")          // معرف الكيان المتأثر

  before      Json?                               // حالة الكيان قبل التغيير
  after       Json?                               // حالة الكيان بعد التغيير
  metadata    Json?                               // بيانات إضافية (apartmentId, month, etc.)

  ipAddress   String?  @map("ip_address")

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

// MonthlyInvestorSnapshot Model - لقطة النسبة الشهرية للمستثمر
// ⚡ تُنشأ تلقائياً عند قفل الشهر لحفظ النسب التاريخية
// تحل مشكلة: تغيير النسبة لا يؤثر على الأشهر المقفلة
model MonthlyInvestorSnapshot {
  id                    String            @id @default(cuid())
  apartmentInvestor     ApartmentInvestor @relation(fields: [apartmentInvestorId], references: [id])
  apartmentInvestorId   String            @map("apartment_investor_id")
  month                 String                                          // "YYYY-MM" format

  percentage            Float                                           // النسبة الفعلية وقت القفل
  investorProfit        Float             @default(0) @map("investor_profit") // ربح المستثمر المحسوب

  createdAt             DateTime          @default(now()) @map("created_at")

  @@unique([apartmentInvestorId, month])
  @@index([month])
  @@map("monthly_investor_snapshots")
}

// OpsManagerApartment Model - تعيين الشقق لمدير التشغيل
// يحدد الشقق التي يكون مدير التشغيل مسؤولاً عنها
model OpsManagerApartment {
  id            String    @id @default(cuid())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String    @map("user_id")
  apartment     Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  apartmentId   String    @map("apartment_id")

  createdAt     DateTime  @default(now()) @map("created_at")

  @@unique([userId, apartmentId])
  @@index([userId])
  @@index([apartmentId])
  @@map("ops_manager_apartments")
}

// Custody Model - نموذج العهدة
// العهدة هي المبلغ الذي يستلمه مدير التشغيل للصرف منها خلال الشهر
model Custody {
  id            String    @id @default(cuid())
  manager       User      @relation("CustodyManager", fields: [managerId], references: [id])
  managerId     String    @map("manager_id")
  apartment     Apartment @relation(fields: [apartmentId], references: [id])
  apartmentId   String    @map("apartment_id")
  month         String                               // "YYYY-MM" format

  amount        Float                                 // مبلغ العهدة
  currency      String    @default("USD")
  spent         Float     @default(0)                 // المصروف الفعلي (من المصروفات المعتمدة)
  remaining     Float     @default(0)                 // المتبقي (محسوب)
  notes         String?

  isSettled     Boolean   @default(false) @map("is_settled")   // تم تقفيل العهدة؟
  settledAt     DateTime? @map("settled_at")

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([managerId, apartmentId, month])
  @@index([managerId])
  @@index([apartmentId, month])
  @@index([month])
  @@map("custody_records")
}

// Invitation Model - دعوات الفريق
// رابط دعوة يُنشئه المدير العام لتسجيل عضو جديد بدور محدد
model Invitation {
  id          String    @id @default(cuid())
  code        String    @unique                    // كود فريد للرابط
  role        Role                                 // الدور المطلوب للعضو الجديد
  createdBy   String    @map("created_by")         // معرف المدير الذي أنشأ الدعوة
  createdByName String  @map("created_by_name")    // اسم المدير
  expiresAt   DateTime  @map("expires_at")         // تاريخ انتهاء الصلاحية (3 أيام)
  used        Boolean   @default(false)            // هل تم استخدام الدعوة؟
  usedAt      DateTime? @map("used_at")            // تاريخ الاستخدام
  usedById    String?   @map("used_by_id")         // معرف المستخدم الذي استخدم الدعوة
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([code])
  @@index([expiresAt])
  @@map("invitations")
}

// SystemBackup Model - النسخ الاحتياطية للنظام
// تُخزَّن في قاعدة البيانات بدلاً من ملفات JSON
model SystemBackup {
  id            String   @id @default(cuid())
  name          String                            // اسم النسخة الاحتياطية
  data          Json                              // بيانات النسخة الكاملة
  stats         Json?                             // إحصائيات ملخصة للعرض
  createdBy     String   @map("created_by")       // معرف المستخدم الذي أنشأ النسخة
  createdByName String   @map("created_by_name")  // اسم المستخدم
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("system_backups")
}
