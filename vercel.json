{
  "version": 2,
  "buildCommand": "prisma generate && prisma db push --accept-data-loss && next build",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/cleanup-verifications",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/refresh-snapshots",
      "schedule": "0 3 * * *"
    }
  ]
}
